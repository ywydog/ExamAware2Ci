<UserControl x:Class="ExamAware2Ci.Controls.Automations.ActionSettingsControls.PlayExamActionSettingsControl"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ci="http://classisland.tech/schemas/xaml/core"
             xmlns:local="using:ExamAware2Ci.Controls.Automations.ActionSettingsControls"
             xmlns:models="using:ExamAware2Ci.Models.Automations.Actions"
             mc:Ignorable="d">
    <UserControl.Resources>
        <!-- ComboBox 数据源与 Enum/Option 转换器（与 RuleSettingsControl 保持同一套模式） -->
        <local:ExamSourceTypeOptionsProvider x:Key="SourceTypeOptions" />
        <local:ExamSourceTypeEnumToOptionConverter x:Key="SourceTypeEnumToOption" />
        <local:ExamSourceTypeOptionToEnumConverter x:Key="SourceTypeOptionToEnum" />
    </UserControl.Resources>

    <StackPanel Orientation="Vertical" VerticalAlignment="Center" Spacing="6"
                DataContext="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:PlayExamActionSettingsControl}}">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <TextBlock VerticalAlignment="Center">来源类型：</TextBlock>
            <ComboBox VerticalAlignment="Center" Width="140"
                      ItemsSource="{Binding Source={StaticResource SourceTypeOptions}, Path=Items}"
                      SelectedItem="{Binding Settings.SourceType,
                                              Converter={StaticResource SourceTypeEnumToOption},
                                              ConverterParameter={StaticResource SourceTypeOptions}}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Label}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <!--
                UpdateSourceTrigger=PropertyChanged：让 TextBox 边输入边回写 Settings.Source，
                避免"测试"按钮在 TextBox 还没失焦时拿到旧值。
            -->
            <TextBox x:Name="SourceBox"
                     VerticalAlignment="Center"
                     Width="380"
                     Watermark="{Binding Settings.SourceType, Converter={x:Static local:SourceWatermarkConverter.Instance}}"
                     Text="{Binding Settings.Source, UpdateSourceTrigger=PropertyChanged}" />
            <Button VerticalAlignment="Center"
                    Name="BtnBrowse"
                    Click="BtnBrowse_Click"
                    ToolTip.Tip="从本机选择一个 .ea2 / .json 考试档案">
                <ci:IconText Glyph="&#xE8E5;" Text="浏览…"/>
            </Button>
            <Button VerticalAlignment="Center"
                    Name="BtnTest"
                    Click="BtnTest_Click"
                    ToolTip.Tip="立即检查该来源是否可用（不会触发放映）">
                <ci:IconText Glyph="&#xE73E;" Text="测试"/>
            </Button>
            <Button VerticalAlignment="Center"
                    Name="BtnClear"
                    Click="BtnClear_Click"
                    ToolTip.Tip="清空当前来源">
                <ci:IconText Glyph="&#xE74D;" Text="清空"/>
            </Button>
        </StackPanel>

        <TextBlock VerticalAlignment="Center"
                   Name="StatusText"
                   FontSize="12"
                   TextWrapping="Wrap"
                   IsVisible="False" />
    </StackPanel>
</UserControl>
