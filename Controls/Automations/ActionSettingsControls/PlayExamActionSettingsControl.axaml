<UserControl x:Class="ExamAware2Ci.Controls.Automations.ActionSettingsControls.PlayExamActionSettingsControl"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ci="http://classisland.tech/schemas/xaml/core"
             xmlns:local="using:ExamAware2Ci.Controls.Automations.ActionSettingsControls"
             xmlns:models="using:ExamAware2Ci.Models.Automations.Actions"
             mc:Ignorable="d">
    <StackPanel Orientation="Vertical" VerticalAlignment="Center" Spacing="6"
                DataContext="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:PlayExamActionSettingsControl}}">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <TextBlock VerticalAlignment="Center">来源类型：</TextBlock>
            <ComboBox VerticalAlignment="Center" Width="120"
                      SelectedIndex="{Binding Settings.SourceType}">
                <ComboBoxItem>
                    <ci:IconText Glyph="&#xE71B;" Text="URL 链接"/>
                </ComboBoxItem>
                <ComboBoxItem>
                    <ci:IconText Glyph="&#xE8E5;" Text="本地文件"/>
                </ComboBoxItem>
            </ComboBox>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <TextBox VerticalAlignment="Center"
                     Width="380"
                     Watermark="{Binding Settings.SourceType, Converter={x:Static local:SourceWatermarkConverter.Instance}}"
                     Text="{Binding Settings.Source}" />
            <Button VerticalAlignment="Center"
                    Name="BtnBrowse"
                    Click="BtnBrowse_Click"
                    ToolTip.Tip="从本机选择一个 .ea2 / .json 考试档案">
                <ci:IconText Glyph="&#xE8E5;" Text="浏览…"/>
            </Button>
            <Button VerticalAlignment="Center"
                    Name="BtnTest"
                    Click="BtnTest_Click"
                    ToolTip.Tip="立即检查该来源是否可用（不会触发放映）">
                <ci:IconText Glyph="&#xE73E;" Text="测试"/>
            </Button>
            <Button VerticalAlignment="Center"
                    Name="BtnClear"
                    Click="BtnClear_Click"
                    ToolTip.Tip="清空当前来源">
                <ci:IconText Glyph="&#xE74D;" Text="清空"/>
            </Button>
        </StackPanel>

        <TextBlock VerticalAlignment="Center"
                   Name="StatusText"
                   FontSize="12"
                   TextWrapping="Wrap"
                   IsVisible="False" />
    </StackPanel>
</UserControl>
